# agu.ai Environment Variables
# Copy this file to .env and fill in your real values
# Never commit .env to GitHub

# =============================================
# FRONTEND (React) - prefix with REACT_APP_
# =============================================

# Anthropic API Key (get from console.anthropic.com)
# Used for: AI chat, soil checker, weather AI, news AI, livestock diagnosis
REACT_APP_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================
# BACKEND (Node.js server)
# =============================================

# Server port
PORT=3000

# MongoDB connection string (get from cloud.mongodb.com)
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/aguai

# Twilio credentials (get from twilio.com/console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Python AI service URL
AI_SERVICE_URL=http://localhost:5000/respond

# =============================================
# PYTHON AI SERVICE
# =============================================

# Anthropic API Key (same as above)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Python service port
AI_SERVICE_PORT=5000

# =============================================
# ADMIN CREDENTIALS (change these!)
# =============================================
ADMIN_EMAIL=admin@agu.ai
ADMIN_PASSWORD=change_this_to_a_strong_password

# =============================================
# OPTIONAL - FOR FUTURE LIVE DATA
# =============================================

# WFP VAM API for live crop prices
WFP_API_KEY=your_wfp_api_key

# Kenya Meteorological Dept API
KMD_API_KEY=your_kmd_api_key

# Africa's Talking (for SMS fallback)
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_africastalking_username
